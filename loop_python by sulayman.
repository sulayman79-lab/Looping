# Pengulangan while
angka = 1
while angka <= 20:
    print("Angka:", angka)
    angka += 1

# pengulangan break
for i in range(20):
    if i == 11:
        break
    print(i, end=" ")

#Pengulangan for
for i in range(20):
    print("Perulangan ke-", i)

#Pengulangan continue 
for i in range(1, 20):
    if i == 10:
        continue 
    print(f"Angka: {i}")
